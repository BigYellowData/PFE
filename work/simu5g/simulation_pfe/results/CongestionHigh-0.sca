config description "Congestion forte - stress eMBB + mMTC + URLLC"
config *.numEmbbUes 12
config *.numUrllcUes 15
config *.numMmtcUes 5
config *.numBestEffortUes 5
config sim-time-limit 1800s
config *.ueEmbb[*].app[0].packetSize 1290B
config *.ueEmbb[*].app[0].samplingTime 0.002s
config *.ueUrllc[*].app[0].packetSize 292B
config *.ueUrllc[*].app[0].samplingTime 0.015s
config *.ueMmtc[*].app[0].packetSize 47B
config *.ueMmtc[*].app[0].samplingTime 2s
config network NetworkSlicing
config sim-time-limit 300s
config seed-set 0
config *.configurator.config "xml(\"<config><interface among='gnb iUpf upf router' address='10.x.x.x' netmask='255.255.255.0'/><interface hosts='*' address='192.168.x.x' netmask='255.255.255.0'/></config>\")"
config output-vector-file results/CongestionHigh-0.vec
config output-scalar-file results/CongestionHigh-0.sca
config **.mac.receivedPacketFromLowerLayer.result-recording-modes -
config **.mac.receivedPacketFromUpperLayer.result-recording-modes -
