version 3
run StressEmbb-0-20260210-14:15:10-84
attr configname StressEmbb
attr datetime 20260210-14:15:10
attr datetimef 20260210-141510
attr experiment StressEmbb
attr inifile omnetpp.ini
attr iterationvars ""
attr iterationvarsd ""
attr iterationvarsf ""
attr measurement ""
attr network NetworkSlicing
attr processid 84
attr repetition 0
attr replication #0
attr resultdir results
attr runnumber 0
attr seedset 0
config description "Saturation eMBB - 20 UEs video haute intensite"
config *.numEmbbUes 20
config *.numUrllcUes 4
config *.numMmtcUes 2
config *.numBestEffortUes 2
config sim-time-limit 1800s
config *.ueEmbb[*].app[0].packetSize 1290B
config *.ueEmbb[*].app[0].samplingTime 0.001s
config *.ueUrllc[*].app[0].packetSize 292B
config *.ueUrllc[*].app[0].samplingTime 0.030s
config *.ueMmtc[*].app[0].packetSize 47B
config *.ueMmtc[*].app[0].samplingTime 5s
config network NetworkSlicing
config sim-time-limit 300s
config seed-set 0
config *.configurator.config "xml(\"<config><interface among='gnb iUpf upf router' address='10.x.x.x' netmask='255.255.255.0'/><interface hosts='*' address='192.168.x.x' netmask='255.255.255.0'/></config>\")"
config output-vector-file results/StressEmbb-0.vec
config output-scalar-file results/StressEmbb-0.sca
config **.mac.receivedPacketFromLowerLayer.result-recording-modes -
config **.mac.receivedPacketFromUpperLayer.result-recording-modes -
config **.mac.sentPacketToLowerLayer.result-recording-modes -
config **.mac.sentPacketToUpperLayer.result-recording-modes -
